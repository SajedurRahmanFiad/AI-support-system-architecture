APP_NAME=B2B AI Support API
APP_ENV=development
DEBUG=true
DATABASE_URL=mysql+pymysql://db_user:db_password@localhost:3306/b2b_ai_support?charset=utf8mb4
PLATFORM_API_TOKEN=change-this-platform-token
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_SUMMARY_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
KNOWLEDGE_SCAN_LIMIT=400
KNOWLEDGE_TOP_K=5
HANDOFF_CONFIDENCE_THRESHOLD=0.55
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_BYTES=20000000
ALLOWED_ORIGINS=*
